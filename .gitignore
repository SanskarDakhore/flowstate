# =============================================================================
# FLOWSTATE — .gitignore
# Covers: Unity, Node.js/TypeScript, IDEs, OS files
# =============================================================================

# ---- OS ----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
!.env.example

# ---- Unity ----
frontend/[Ll]ibrary/
frontend/[Tt]emp/
frontend/[Oo]bj/
frontend/[Bb]uild/
frontend/[Bb]uilds/
frontend/[Ll]ogs/
frontend/[Uu]ser[Ss]ettings/
frontend/[Mm]emory[Cc]aptures/
frontend/[Rr]ecordings/
frontend/Assets/Plugins/Editor/JetBrains*
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
*.unitypackage
*.apk
*.aab
*.ipa

# Unity meta files for directories (keep meta files for assets)
# Do NOT ignore .meta files globally — Unity requires them

# ---- IDE ----
.idea/
.vs/
.vscode/
*.suo
*.user
*.userprefs
*.csproj
*.sln
*.pidb
*.pdb
*.mdb

# ---- Node.js / TypeScript ----
node_modules/
dist/
build/
*.js.map
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz
.pnp.*

# ---- Coverage & Testing ----
coverage/
.nyc_output/
*.lcov
test-results/

# ---- Docker ----
docker-compose.override.yml

# ---- Database ----
database/backups/*.sql
database/backups/*.dump
*.sqlite
*.sqlite3

# ---- Misc ----
*.log
*.tmp
*.bak
*.orig
