# =============================================================================
# FLOWSTATE — EditorConfig
# https://editorconfig.org
# =============================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# C# (Unity)
[*.cs]
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# SQL
[*.sql]
indent_size = 2
