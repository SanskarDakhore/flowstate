# =============================================================================
# FLOWSTATE — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env
# =============================================================================

# ---- Application ----
NODE_ENV=development
APP_PORT=3000
APP_NAME=flowstate-api
APP_VERSION=0.1.0

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowstate_dev
DB_USER=flowstate
DB_PASSWORD=CHANGE_ME
DB_SSL=false

# ---- Authentication ----
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- CORS ----
CORS_ORIGIN=*

# ---- Logging ----
LOG_LEVEL=debug

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Feature Flags ----
FEATURE_LEADERBOARDS=true
FEATURE_COSMETICS=false
FEATURE_ANALYTICS=false

# ---- External Services (TBD) ----
# ANALYTICS_API_KEY=
# REMOTE_CONFIG_URL=
# CLOUD_STORAGE_BUCKET=
